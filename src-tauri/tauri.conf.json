{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Float Timer",
  "version": "0.1.0",
  "identifier": "com.floattimer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Float Timer",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
