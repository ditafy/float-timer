{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Float Timer",
  "version": "0.1.0",
  "identifier": "com.mayuxuan.floattimer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Float Timer",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "decorations": true
      },
      {
        "label": "mini",
        "title": "Float Timer",
        "width": 350,
        "height": 160,
        "minWidth": 350,
        "minHeight": 160,
        "maxWidth": 900,
        "maxHeight": 320,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
